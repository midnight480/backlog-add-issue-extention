{
  "name": "backlog-add-issue-extension",
  "version": "1.0.0",
  "description": "Chrome拡張機能として、BacklogのAPIキー管理と課題追加機能を提供するシステム",
  "main": "manifest.json",
  "scripts": {
    "test": "jest --verbose",
    "test:watch": "jest --watch --verbose",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "echo 'Linting not configured yet'",
    "build": "echo 'Build process not required for Chrome extension'",
    "package": "echo 'Use Chrome Extensions Developer Dashboard to package'"
  },
  "keywords": [
    "chrome-extension",
    "backlog",
    "issue-tracker",
    "productivity",
    "manifest-v3",
    "service-worker"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "bugs": {
    "url": ""
  },
  "homepage": "",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.254",
    "fast-check": "^3.15.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/test/setup.js"
    ],
    "collectCoverageFrom": [
      "background/**/*.js",
      "content/**/*.js",
      "sidepanel/**/*.js",
      "!**/node_modules/**",
      "!**/test/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "testMatch": [
      "**/test/**/*.test.js"
    ],
    "verbose": true
  }
}
